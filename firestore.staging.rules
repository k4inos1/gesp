rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección de usuarios en staging
    match /users/{userId} {
      // Permitir operaciones básicas para testing
      allow read, write: if request.auth != null;
    }
    
    // Otras colecciones
    match /{document=**} {
      // En staging, permitir más acceso para facilitar pruebas
      allow read, write: if request.auth != null;
    }
  }
}
