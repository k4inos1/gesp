rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Cualquiera puede crear un perfil (para registro)
      allow create: if request.auth != null && 
                   request.resource.data.email == request.auth.token.email;
      
      // Solo el usuario dueño o un admin puede leer/actualizar/eliminar
      allow read, update, delete: if isOwner(userId) || isAdmin();
    }
    
    // Reglas para otras colecciones (ajustar según necesidades)
    match /{document=**} {
      // Por defecto, solo lectura/escritura para autenticados
      allow read: if request.auth != null;
      allow write: if false; // Por defecto, no permitir escritura
    }
    
    // Funciones auxiliares
    function isOwner(userId) {
      return request.auth != null && userId == request.auth.uid;
    }
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }
  }
}
