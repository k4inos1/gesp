{
  "name": "gesapp-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "node --max_old_space_size=8192 ./node_modules/@angular/cli/bin/ng",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "npm run ng -- serve --port 4200 --open",
    "start:backend": "cd backend && npm run dev",
    "start:prod": "npm run ng -- serve --configuration production",
    "build": "npm run ng -- build --output-path=dist/gesapp-angular",
    "build:prod": "npm run ng -- build --configuration production --output-path=dist/gesapp-angular --output-hashing=all",
    "build:stats": "npm run ng -- build --stats-json --configuration production --output-path=dist/gesapp-angular",
    "watch": "npm run ng -- build --watch --configuration development --output-path=dist/gesapp-angular",
    "analyze": "npm run build:stats && npx webpack-bundle-analyzer dist/gesapp-angular/stats.json",
    "lint": "npm run ng -- lint",
    "test": "npm run ng -- test",
    "test:ci": "npm run ng -- test --watch=false --browsers=ChromeHeadless",
    "e2e": "npm run ng -- e2e",
    "generate:component": "npm run ng -- generate component",
    "generate:service": "npm run ng -- generate service",
    "generate:module": "npm run ng -- generate module",
    "clean": "npx rimraf dist",
    "update": "npm run ng -- update",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "install:all": "npm install && cd backend && npm install",
    "render:build": "npm install && npm run build:prod",
    "render:deploy": "npm run render:build"
  },
  "prepare": "npm install -g @angular/cli",
  "private": true,
  "engines": {
    "node": "18.16.0"
  },
  "dependencies": {
    "@angular/animations": "^17.3.12",
    "@angular/cdk": "^17.0.0",
    "@angular/common": "^17.3.12",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.3.12",
    "@angular/fire": "^17.0.1",
    "@angular/forms": "^17.3.12",
    "@angular/material": "17.3.10",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.3.12",
    "@swimlane/ngx-charts": "^20.1.0",
    "chart.js": "^4.0.0",
    "firebase": "^10.8.0",
    "mqtt": "^5.0.0",
    "ng2-charts": "^5.0.0",
    "ngx-mqtt": "^17.0.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.7.0",
    "three": "^0.160.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular-eslint/builder": "^19.7.0",
    "@angular-eslint/eslint-plugin": "^19.7.0",
    "@angular-eslint/eslint-plugin-template": "^19.7.0",
    "@angular-eslint/schematics": "^19.7.0",
    "@angular-eslint/template-parser": "^19.7.0",
    "@angular/cli": "^17.3.17",
    "@angular/compiler-cli": "^17.0.0",
    "@types/jasmine": "^5.1.8",
    "@types/node": "^22.15.29",
    "concurrently": "^8.2.2",
    "jasmine-core": "^5.7.1",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.2.2",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
