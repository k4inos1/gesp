{
  "name": "gesapp-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "ng serve --configuration development --port 4200 --open",
    "dev:backend": "cd backend && npm run dev",
    "watch": "ng build --watch --configuration development --output-path=dist/gesapp-angular",
    "build": "ng build --output-path=dist/gesapp-angular",
    "build:development": "ng build --configuration=development --output-path=dist/gesapp-angular",
    "build:staging": "ng build --configuration=staging --output-path=dist/gesapp-angular --output-hashing=all",
    "build:prod": "ng build --configuration=production --output-hashing=all --output-path=dist/gesapp-angular",
    "build:stats": "ng build --stats-json --configuration production --output-path=dist/gesapp-angular",
    "analyze": "npm run build:stats && npx webpack-bundle-analyzer dist/gesapp-angular/stats.json",
    "serve:staging": "ng serve --configuration=staging --port 4300",
    "serve:prod": "ng serve --configuration=production --port 4400",
    "preview:prod": "http-server dist/gesapp-angular -p 4400 -c-1",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "npm run build && firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore",
    "emulators": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "emulators:all": "firebase emulators:start --import=./emulator-data --export-on-exit --inspect-functions",
    "test": "ng test",
    "e2e": "ng e2e",
    "lint": "ng lint"
  },
  "prepare": "npm install -g @angular/cli",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "dependencies": {
    "@angular/animations": "^17.3.12",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "17.3.0",
    "@angular/compiler": "17.3.0",
    "@angular/core": "17.3.0",
    "@angular/fire": "^17.1.0",
    "@angular/forms": "17.3.0",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "17.3.0",
    "@angular/platform-browser-dynamic": "17.3.0",
    "@angular/router": "17.3.0",
    "@angular/service-worker": "17.3.0",
    "@auth0/angular-jwt": "^5.2.0",
    "@firebase/app-compat": "^0.4.1",
    "@firebase/auth-compat": "^0.5.26",
    "@firebase/firestore": "^4.7.17",
    "@firebase/firestore-compat": "^0.3.52",
    "@firebasegen/default-connector": "file:dataconnect-generated/js/default-connector",
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@types/grecaptcha": "^3.0.9",
    "@types/passport-local": "^1.0.38",
    "dotenv": "^16.5.0",
    "firebase": "^10.14.1",
    "ng-recaptcha": "^13.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "save": "^2.9.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular-eslint/builder": "17.3.0",
    "@angular-eslint/eslint-plugin": "17.3.0",
    "@angular-eslint/eslint-plugin-template": "17.3.0",
    "@angular-eslint/schematics": "17.3.0",
    "@angular-eslint/template-parser": "17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "17.3.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@types/jasmine": "~5.1.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/jest": "^29.5.14",
    "@types/karma": "^6.3.9",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "7.2.0",
    "@typescript-eslint/parser": "7.2.0",
    "eslint": "^8.57.0",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "karma-spec-reporter": "0.0.34",
    "protractor": "~7.0.0",
    "puppeteer": "^21.11.0",
    "stylelint": "^16.20.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-scss": "^6.12.0",
    "ts-node": "~10.9.1",
    "typescript": "~5.3.2"
  },
  "overrides": {
    "multer": "^2.2.0",
    "body-parser": "^1.20.3",
    "qs": "^6.15.2",
    "multer": "^2.2.0",
    "protobufjs": "^7.6.3",
    "shell-quote": "^1.8.2",
    "basic-ftp": "^5.0.4",
    "vite": "^5.4.20",
    "rollup": "^4.59.0"
    "ws": "^8.17.1",
    "tar-fs": "^3.1.2"
    "glob": "^10.5.0"
  },
  "description": "Aplicación web desarrollada con Angular 17 y Firebase para la gestión integral de procesos.",
  "main": "karma.conf.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
